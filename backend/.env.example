# Backend Environment Variables Example
SECRET_KEY=your_secret_key_here
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/autoagent
REDIS_URL=redis://127.0.0.1:6379/0
CHROMA_URL=http://127.0.0.1:8001
LOG_LEVEL=INFO

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Settings
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Groq API Key for Chat & Reasoning
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM API Key for Image Generation & Chat
HUGGINGFACE_API_KEY=your_huggingface_key_here
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Default Chat API Key (NVIDIA NIM — primary chat model)
DEFAULT_CHAT_API_KEY=your_nvidia_api_key_here
DEFAULT_CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b

# Voyage AI API Key for Knowledge Base (RAG)
VOYAGE_API_KEY=your_voyage_key_here
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2.5

# Google Gemini API Key for Vision (Image Understanding)
GOOGLE_API_KEY=your_google_api_key_here
VISION_MODEL=gemini-1.5-flash

# Groq API Key for Speech-to-Text (STT)
GROQ_STT_API_KEY=your_groq_stt_key_here
GROQ_STT_MODEL=whisper-large-v3

# Unreal Speech API Key for Text-to-Speech (TTS)
UNREAL_SPEECH_API_KEY=your_unreal_speech_key_here
UNREAL_SPEECH_VOICE=Sierra

# Multi-Agent Code Orchestration (NVIDIA NIM — GLM 5.2)
PLANNER_API_KEY=your_nvidia_api_key_here
PLANNER_MODEL=z-ai/glm-5.2
CODER_API_KEY=your_nvidia_api_key_here
CODER_MODEL=z-ai/glm-5.2
