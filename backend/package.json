{
  "name": "infichat-backend",
  "version": "2.0.0",
  "private": true,
  "description": "InfiChat Backend API — FastAPI + Python",
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8080",
    "dev:venv": "venv\\Scripts\\python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8080",
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8080",
    "start:venv": "venv\\Scripts\\python -m uvicorn app.main:app --host 0.0.0.0 --port 8080",
    "seed": "python -c \"from app.services.seed_plans import seed_plans; seed_plans()\"",
    "shell": "venv\\Scripts\\python",
    "install:deps": "pip install -r requirements.txt",
    "install:venv": "venv\\Scripts\\python -m pip install -r requirements.txt"
  }
}
